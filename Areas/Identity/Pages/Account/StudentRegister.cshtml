@page
@model StudentRegisterModel
@{
    ViewData["Title"] = "Student Registration";
}

<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-6">
        <form id="studentRegisterForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <h2>Create your student account</h2>
            <hr />
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.FullName" class="form-control" placeholder="Full Name" />
                <label asp-for="Input.FullName">Full Name</label>
                <span asp-validation-for="Input.FullName" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.RollNumber" class="form-control" placeholder="Roll Number" />
                <label asp-for="Input.RollNumber">Roll Number</label>
                <span asp-validation-for="Input.RollNumber" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <select asp-for="Input.SectionId" asp-items="Model.Sections" class="form-select">
                    <option value="">-- Select your Section --</option>
                </select>
                <label asp-for="Input.SectionId">Section</label>
                <span asp-validation-for="Input.SectionId" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" placeholder="password" />
                <label asp-for="Input.Password">Password</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="confirm password" />
                <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>
            <button id="studentRegisterSubmit" type="submit" class="w-100 btn btn-lg btn-primary">Register</button>
        </form>
    </div>
</div>
