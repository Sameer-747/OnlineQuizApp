@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
}

<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-6">
        <section>
            <div class="btn-group mb-3 w-100" role="group">
                <button type="button" class="btn btn-outline-primary" id="studentTabBtn" onclick="showTab('student')">Student Login</button>
                <button type="button" class="btn btn-outline-primary" id="adminTabBtn" onclick="showTab('admin')">Admin Login</button>
            </div>

            <form id="account" method="post">
                <input type="hidden" asp-for="Input.LoginType" id="loginTypeInput" value="student" />
                <hr />
                <div asp-validation-summary="All" class="text-danger"></div>

                <div id="studentFields">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.RollNumber" class="form-control" autocomplete="username" placeholder="Roll Number" />
                        <label asp-for="Input.RollNumber">Roll Number</label>
                    </div>
                    <div class="form-floating mb-3">
                        <select asp-for="Input.SectionId" asp-items="Model.Sections" class="form-select">
                            <option value="">-- Select your Section --</option>
                        </select>
                        <label asp-for="Input.SectionId">Section</label>
                    </div>
                </div>

                <div id="adminFields" style="display:none">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                        <label asp-for="Input.Email">Email</label>
                    </div>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="password" />
                    <label asp-for="Input.Password">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="checkbox mb-3">
                    <label asp-for="Input.RememberMe" class="form-label">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>
                <div>
                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Log in</button>
                </div>
                <div class="mt-2">
                    <p>
                        <a asp-page="./StudentRegister" asp-route-returnUrl="@Model.ReturnUrl">Register as a new student</a>
                    </p>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <script>
        function showTab(type) {
            document.getElementById('loginTypeInput').value = type;
            document.getElementById('studentFields').style.display = type === 'student' ? 'block' : 'none';
            document.getElementById('adminFields').style.display = type === 'admin' ? 'block' : 'none';
            document.getElementById('studentTabBtn').classList.toggle('btn-primary', type === 'student');
            document.getElementById('studentTabBtn').classList.toggle('btn-outline-primary', type !== 'student');
            document.getElementById('adminTabBtn').classList.toggle('btn-primary', type === 'admin');
            document.getElementById('adminTabBtn').classList.toggle('btn-outline-primary', type !== 'admin');
        }
        showTab('student');
    </script>
}
