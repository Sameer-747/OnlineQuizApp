@using OnlineQuizApp.Models
@model ApplicationUser
@{
    ViewData["Title"] = "My Profile";
    bool isStudent = !string.IsNullOrEmpty(Model.RollNumber);
}

<h2><i class="ti ti-user-circle me-2"></i>My Profile</h2>

<div class="card" style="max-width: 480px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Full Name</dt>
            <dd class="col-sm-8">@(Model.FullName ?? "-")</dd>

            @if (isStudent)
            {
                <dt class="col-sm-4">Roll Number</dt>
                <dd class="col-sm-8">@Model.RollNumber</dd>

                <dt class="col-sm-4">Section</dt>
                <dd class="col-sm-8">@(Model.Section?.Name ?? "Unassigned")</dd>
            }
            else
            {
                <dt class="col-sm-4">Email</dt>
                <dd class="col-sm-8">@Model.Email</dd>

                <dt class="col-sm-4">Role</dt>
                <dd class="col-sm-8">Admin</dd>

                @if (Model.Section != null)
                {
                    <dt class="col-sm-4">Manages Section</dt>
                    <dd class="col-sm-8">@Model.Section.Name</dd>
                }
            }
        </dl>
    </div>
</div>
