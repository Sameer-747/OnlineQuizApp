@model List<Category>
@{
    ViewData["Title"] = "Manage Categories";
}

<h2>Categories</h2>
<a asp-action="Create" class="btn btn-primary mb-3">+ New Category</a>

<table class="table table-striped">
    <thead>
        <tr><th>Name</th><th>Quizzes</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var cat in Model)
        {
            <tr>
                <td>@cat.Name</td>
                <td>@cat.Quizzes.Count</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
