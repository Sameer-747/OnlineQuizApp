@using OnlineQuizApp.Models
@model List<ApplicationUser>
@{
    ViewData["Title"] = "Manage Admins";
    var adminUserIds = ViewBag.AdminUserIds as HashSet<string> ?? new HashSet<string>();
}

<h2><i class="ti ti-shield-check me-2"></i>Manage Admins</h2>
<p class="text-muted">Promote registered users to Admin or remove their Admin role.</p>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="ti ti-check me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="ti ti-alert-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            var isAdmin = adminUserIds.Contains(user.Id);
            <tr>
                <td>@(user.FullName ?? "-")</td>
                <td>@user.Email</td>
                <td>
                    @if (isAdmin)
                    {
                        <span class="badge bg-danger">Admin</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">User</span>
                    }
                </td>
                <td>
                    @if (isAdmin)
                    {
                        <form method="post" asp-controller="AdminManagement" asp-action="Demote" style="display:inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="userId" value="@user.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('Remove Admin role from @user.Email?')">
                                <i class="ti ti-shield-off me-1"></i>Remove Admin
                            </button>
                        </form>
                    }
                    else
                    {
                        <form method="post" asp-controller="AdminManagement" asp-action="Promote" style="display:inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="userId" value="@user.Id" />
                            <button type="submit" class="btn btn-sm btn-success">
                                <i class="ti ti-shield-check me-1"></i>Make Admin
                            </button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
