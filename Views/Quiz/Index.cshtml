@model List<Quiz>
@{
    ViewData["Title"] = "Quizzes";
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
    int? selectedCategoryId = ViewBag.SelectedCategoryId;
}

<h2 class="mb-3"><i class="ti ti-list-details me-2"></i>Available Quizzes</h2>

<div class="mb-4">
    <div class="btn-group flex-wrap" role="group">
        <a asp-action="Index" class="btn btn-sm @(selectedCategoryId == null ? "btn-primary" : "btn-outline-primary")">All</a>
        @foreach (var cat in categories)
        {
            <a asp-action="Index" asp-route-categoryId="@cat.Id"
               class="btn btn-sm @(selectedCategoryId == cat.Id ? "btn-primary" : "btn-outline-primary")">
                @cat.Name
            </a>
        }
    </div>
</div>

<div class="row">
    @foreach (var quiz in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="d-inline-flex align-items-center justify-content-center"
                              style="width:40px;height:40px;border-radius:12px;background:linear-gradient(135deg,#6e8efb,#a777e3);color:#fff;">
                            <i class="ti ti-clipboard-text" style="font-size:20px"></i>
                        </span>
                        <h5 class="card-title mb-0">@quiz.Title</h5>
                    </div>
                    <p class="mb-1" style="color:#5b5b7a;"><i class="ti ti-category me-1"></i>@quiz.Category?.Name</p>
                    <p class="card-text flex-grow-1">@quiz.Description</p>
                    <p class="mb-3"><span class="badge" style="background: rgba(110,142,251,0.18); color:#4b4b9a;"><i class="ti ti-clock me-1"></i>@quiz.DurationMinutes min</span></p>
                    <div class="d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@quiz.Id" class="btn btn-outline-secondary btn-sm">
                            <i class="ti ti-info-circle me-1"></i>Details
                        </a>
                        <a asp-action="Take" asp-route-id="@quiz.Id" class="btn btn-primary btn-sm">
                            <i class="ti ti-player-play me-1"></i>Take Quiz
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="ti ti-info-circle me-1"></i>No quizzes found in this category.
    </div>
}
