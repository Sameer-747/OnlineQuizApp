<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Online Quiz App</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/dist/tabler-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light glass-navbar mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <i class="ti ti-sparkles" style="font-size:22px"></i>
                    Online Quiz App
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navMenu">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="ti ti-home me-1"></i>Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Quiz" asp-action="Index"><i class="ti ti-list-details me-1"></i>Quizzes</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Quiz" asp-action="History"><i class="ti ti-history me-1"></i>My History</a>
                            </li>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Category" asp-action="Index"><i class="ti ti-category me-1"></i>Categories</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="QuizAdmin" asp-action="Index"><i class="ti ti-settings me-1"></i>Manage Quizzes</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="ResultsAdmin" asp-action="Index"><i class="ti ti-chart-bar me-1"></i>Student Results</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="AdminManagement" asp-action="Index"><i class="ti ti-shield-check me-1"></i>Manage Admins</a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="glass-footer text-center py-3 mt-5">
        <div class="container">
            &copy; @DateTime.Now.Year - Online Quiz App
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
