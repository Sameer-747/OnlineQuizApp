@using Microsoft.AspNetCore.Identity
@using OnlineQuizApp.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        var currentUser = await UserManager.GetUserAsync(User);
        var displayName = !string.IsNullOrWhiteSpace(currentUser?.FullName) ? currentUser!.FullName : User.Identity?.Name;

        <li class="nav-item">
            <span class="nav-link text-dark"><i class="ti ti-user-circle me-1"></i>Hello, @displayName!</span>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                <button type="submit" class="nav-link btn btn-link"><i class="ti ti-logout me-1"></i>Logout</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link" asp-area="Identity" asp-page="/Account/Register"><i class="ti ti-user-plus me-1"></i>Register</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-area="Identity" asp-page="/Account/Login"><i class="ti ti-login me-1"></i>Login</a>
        </li>
    }
</ul>
